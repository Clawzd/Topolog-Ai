# Copy to `.env` and fill in values. Vite only reads env files in this folder (next to package.json).
# Names must use the VITE_ prefix or the client will never see them. Restart `npm run dev` after edits.
# Vite is configured so `.env` is read from the folder that contains `vite.config.js` (not only `process.cwd()`).
# App code must reference `import.meta.env.VITE_*` by name (not via a variable holding `import.meta.env`) or values stay empty.

# `deepseek` + a non-empty VITE_DEEPSEEK_API_KEY enables the DeepSeek API.
# Anything else (e.g. `local`) uses the built-in planner only.
VITE_TOPOLOGAI_PROVIDER=local

VITE_DEEPSEEK_API_KEY=
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com
VITE_DEEPSEEK_MODEL=deepseek-chat

# Dev server (`npm run dev`) proxies /deepseek-api → api.deepseek.com with your key (avoids browser CORS).
# Production static builds still need your own backend or edge function if you call DeepSeek from the browser.
