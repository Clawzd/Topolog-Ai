# Copy to `.env` and fill in values. Vite only reads env files in this folder (next to package.json).

# `deepseek` + a non-empty VITE_DEEPSEEK_API_KEY enables the DeepSeek API.
# Anything else (e.g. `local`) uses the built-in planner only.
VITE_TOPOLOGAI_PROVIDER=local

VITE_DEEPSEEK_API_KEY=
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com
VITE_DEEPSEEK_MODEL=deepseek-chat
